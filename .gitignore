# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.ipynb_checkpoints/
.venv/
venv/
env/

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# --- Environment & secrets ---
.env
.env.*
!.env.example
!.env.*.example

# --- Data (large/raw files should not live in git) ---
data/raw/*
!data/raw/README.md
!data/raw/.gitkeep
data/processed/*.csv
data/processed/*.parquet
data/processed/*.geojson
!data/processed/.gitkeep
# Small, reproducible seed tables ARE tracked -- these are what Milestone 3's
# database actually loads, and they're tiny (a few hundred KB to a couple MB).
# The large incident-level table and the redundant neighborhoods.geojson (both
# regenerable via `python scripts/run_pipeline.py`) are intentionally excluded.
!data/processed/monthly_aggregates.parquet
!data/processed/neighborhoods.parquet

# --- Databases ---
*.sqlite3
*.db
pgdata/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Build artifacts ---
dist/
build/
coverage/
