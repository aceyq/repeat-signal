# Copy to .env (in this backend/ folder) and fill in real values. Never commit .env.

# Local native Postgres (Homebrew): default superuser is your macOS username, no
# password, default port 5432. Adjust db name/user/password to match your setup.
DATABASE_URL=postgresql+psycopg://localhost:5432/repeat_signal

# Comma-separated list of origins allowed to call this API from a browser.
# Add the deployed Vercel URL here once the frontend is deployed (Milestone 10).
CORS_ORIGINS=http://localhost:3000
